				., ., ., ., ., ., ., ., ., ., ., ., ., ., ., ., ., ., ., ., ., ., .]
			)
		)
	)) << Run Formulas;
	table1 << Graph Builder(
		Size( 701, 600 ),
		Variables(
			X( :"system:time_start"n ),
			Y( :poppyAreaSqKm ),
			Overlay( :Name ),
			Color( :Name )
		),
		Elements( Line( X, Y, Legend( 9 ) ) ),
		SendToReport(
			Dispatch( {}, "graph title", TextEditBox,
				{Set Text( "Poppy Area and ppt vs Date 2023" )}
			)
		)
	);
)